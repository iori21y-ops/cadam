# ============================================================
# cadam-web 환경변수 템플릿 (.env.example)
# 기준: 구현 명세서 §3.2 키 이름 목록 + 현재 코드에서 실제 사용 중인 키
# 사용법: 이 파일을 .env.local 로 복사한 뒤 각 값을 채운다.
# ⚠️ 실제 값(키/토큰/비밀번호)은 절대 이 파일에 적지 않는다. .env.local 만 사용.
# 규칙: NEXT_PUBLIC_* = 브라우저 공개용. 그 외는 서버 전용(클라이언트 노출 금지).
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # 서버 전용. app/api 라우트에서만 사용

# --- Upstash Redis (레이트리밋/캐시) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- 이메일 발송 (Resend) ---
RESEND_API_KEY=

# --- n8n 자동화 ---
N8N_API_KEY=

# --- Telegram 알림 ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- WordPress 연동 ---
NEXT_PUBLIC_WP_API_URL=
SYNC_WP_SECRET=

# --- 공공데이터포털 ---
DATA_GO_KR_KEY=

# --- Kakao (채널/JS SDK) ---
NEXT_PUBLIC_KAKAO_JS_KEY=
NEXT_PUBLIC_KAKAO_CHANNEL_URL=

# --- Analytics (GA4) ---
NEXT_PUBLIC_GA_ID=

# --- 관리자/기타 ---
ADMIN_EMAIL=
NEXT_PUBLIC_PHONE_NUMBER=         # 대표 전화번호(공개 표시용, §3.2 미기재·현재 사용 중)
REVALIDATION_SECRET=              # ISR revalidate 보호 토큰(§3.2 미기재·현재 사용 중)

# --- 고객 인증(카카오 알림톡 OTP, §6.4) — 서버 전용 ---
MEMBER_OTP_MODE=                  # stub(기본·템플릿 심사 전) | live(실발송). 미설정=stub
# 발송 대행사(1차=솔라피, 리셀러 교체 가능). 값 절대 커밋 금지.
SOLAPI_API_KEY=                   # 대행사 API 키
SOLAPI_API_SECRET=                # 대행사 API 시크릿
SOLAPI_PFID=                      # 카카오 발신프로필 키(채널)
SOLAPI_OTP_TEMPLATE_ID=           # 인증번호 알림톡 템플릿 ID(심사 통과분)
SOLAPI_SENDER_PHONE=              # 발신번호(알림톡 실패 시 SMS 대체발송 발신)
# 참고: NEXT_PUBLIC_KAKAO_CHANNEL_URL=상담채널 링크 · NEXT_PUBLIC_KAKAO_JS_KEY=지도 SDK
#       → 둘 다 로그인/알림톡과 무관. 알림톡은 위 SOLAPI_* 대행사 키 사용.

# ============================================================
# 신규 모듈 연동 시 추가 예정 (현재 미사용 — 명세서 참조)
#   ECOS_API_KEY            # 한국은행 기준금리(§3.4D)
#   MOLIT_VEHICLE_API_KEY   # 국토부 자동차종합정보(§3.4E-2)
# ============================================================
